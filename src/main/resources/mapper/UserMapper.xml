<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.mybatis.mapper.UserMapper">

    <!-- 基礎結果映射 -->
    <resultMap id="BaseResultMap" type="User">
        <id property="id" column="id"/>
        <result property="username" column="username"/>
        <result property="email" column="email"/>
        <result property="age" column="age"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <!-- 帶訂單的結果映射 (一對多) -->
    <resultMap id="UserWithOrdersResultMap" type="User" extends="BaseResultMap">
        <collection property="orders" ofType="Order">
            <id property="id" column="order_id"/>
            <result property="userId" column="user_id"/>
            <result property="product" column="product"/>
            <result property="amount" column="amount"/>
            <result property="status" column="status"/>
            <result property="createdAt" column="order_created_at"/>
        </collection>
    </resultMap>

    <!-- 通用欄位列表 -->
    <sql id="Base_Column_List">
        id, username, email, age, created_at, updated_at
    </sql>

    <!-- 根據 ID 查詢 -->
    <select id="selectById" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM users
        WHERE id = #{id}
    </select>

    <!-- 查詢所有使用者 -->
    <select id="selectAll" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM users
        ORDER BY id
    </select>

    <!--
        動態 SQL 示範: <where> + <if>
        只有在參數非 null 時才加入對應的查詢條件
    -->
    <select id="selectByCondition" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM users
        <where>
            <if test="username != null and username != ''">
                AND username LIKE CONCAT('%', #{username}, '%')
            </if>
            <if test="email != null and email != ''">
                AND email LIKE CONCAT('%', #{email}, '%')
            </if>
            <if test="minAge != null">
                AND age &gt;= #{minAge}
            </if>
            <if test="maxAge != null">
                AND age &lt;= #{maxAge}
            </if>
        </where>
        ORDER BY id
    </select>

    <!-- 一對多關聯查詢: 查詢使用者及其所有訂單 -->
    <select id="selectWithOrders" resultMap="UserWithOrdersResultMap">
        SELECT
            u.id, u.username, u.email, u.age, u.created_at, u.updated_at,
            o.id AS order_id, o.user_id, o.product, o.amount, o.status,
            o.created_at AS order_created_at
        FROM users u
        LEFT JOIN orders o ON u.id = o.user_id
        WHERE u.id = #{id}
    </select>

    <!--
        動態 SQL 示範: <foreach>
        批次查詢多個 ID 的使用者
    -->
    <select id="selectByIds" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM users
        WHERE id IN
        <foreach collection="ids" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </select>

    <!-- 新增使用者，使用 useGeneratedKeys 回填主鍵 -->
    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO users (username, email, age)
        VALUES (#{username}, #{email}, #{age})
    </insert>

    <!--
        動態 SQL 示範: <set> + <if>
        只更新非 null 的欄位，避免覆蓋已有資料
    -->
    <update id="updateSelective">
        UPDATE users
        <set>
            <if test="username != null">username = #{username},</if>
            <if test="email != null">email = #{email},</if>
            <if test="age != null">age = #{age},</if>
            updated_at = CURRENT_TIMESTAMP,
        </set>
        WHERE id = #{id}
    </update>

    <!-- 根據 ID 刪除 -->
    <delete id="deleteById">
        DELETE FROM users WHERE id = #{id}
    </delete>

    <!-- 統計使用者數量 -->
    <select id="count" resultType="int">
        SELECT COUNT(*) FROM users
    </select>

</mapper>

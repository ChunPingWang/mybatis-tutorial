<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.mybatis.mapper.ProductMapper">

    <!-- ============================================================
         基礎結果映射
         ============================================================ -->
    <resultMap id="BaseResultMap" type="Product">
        <id property="id" column="id"/>
        <result property="name" column="name"/>
        <result property="categoryId" column="category_id"/>
        <result property="price" column="price"/>
        <result property="stock" column="stock"/>
        <result property="status" column="status"/>
        <result property="description" column="description"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <!--
        巢狀查詢結果映射 (Nested Select)
        使用 select 屬性指定子查詢，MyBatis 會自動呼叫該查詢來載入關聯物件。
        配合 lazyLoadingEnabled=true，可實現延遲載入。
    -->
    <resultMap id="ProductWithCategoryResultMap" type="Product" extends="BaseResultMap">
        <association property="category" column="category_id"
                     javaType="Category"
                     select="selectCategoryById"/>
    </resultMap>

    <!-- 分類的子查詢 (供巢狀查詢使用) -->
    <select id="selectCategoryById" resultType="Category">
        SELECT id, name FROM categories WHERE id = #{id}
    </select>

    <!-- 通用欄位列表 -->
    <sql id="Base_Column_List">
        id, name, category_id, price, stock, status, description, created_at, updated_at
    </sql>

    <!-- 通用查詢條件片段 (可被多個 SQL 引用) -->
    <sql id="Common_Where_Condition">
        <if test="name != null and name != ''">
            AND name LIKE CONCAT('%', #{name}, '%')
        </if>
        <if test="status != null and status != ''">
            AND status = #{status}
        </if>
        <if test="categoryId != null">
            AND category_id = #{categoryId}
        </if>
    </sql>

    <!-- ============================================================
         基本查詢
         ============================================================ -->

    <select id="selectById" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM products
        WHERE id = #{id}
    </select>

    <select id="selectAll" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM products
        ORDER BY id
    </select>

    <select id="selectByCategoryId" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM products
        WHERE category_id = #{categoryId}
        ORDER BY id
    </select>

    <!-- ============================================================
         示範 1: <choose> / <when> / <otherwise>
         類似 Java 的 switch-case，只會進入第一個匹配的分支
         ============================================================ -->

    <!--
        動態排序: 根據傳入的 orderBy 參數選擇排序欄位。
        注意: 排序欄位使用 ${} 而非 #{}，因為 ORDER BY 不接受預編譯參數。
        為防止 SQL 注入，在 <when> 中白名單限制允許的值。
    -->
    <select id="selectWithDynamicSort" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM products
        <where>
            status != 'DISCONTINUED'
        </where>
        ORDER BY
        <choose>
            <when test="orderBy == 'price'">
                price ASC
            </when>
            <when test="orderBy == 'stock'">
                stock DESC
            </when>
            <when test="orderBy == 'name'">
                name ASC
            </when>
            <otherwise>
                id ASC
            </otherwise>
        </choose>
    </select>

    <!--
        根據價格區間查詢: 使用 choose 判斷價格區間名稱，映射到具體的 SQL 條件。
        - "cheap":     price < 50
        - "medium":    50 <= price <= 100
        - "expensive": price > 100
        - 其他:        不限制價格
    -->
    <select id="selectByPriceRange" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM products
        <where>
            <choose>
                <when test="priceRange == 'cheap'">
                    AND price &lt; 50
                </when>
                <when test="priceRange == 'medium'">
                    AND price &gt;= 50 AND price &lt;= 100
                </when>
                <when test="priceRange == 'expensive'">
                    AND price &gt; 100
                </when>
            </choose>
            <if test="status != null and status != ''">
                AND status = #{status}
            </if>
        </where>
        ORDER BY price
    </select>

    <!--
        使用 choose 統計不同條件的商品數量
    -->
    <select id="countByType" resultType="int">
        SELECT COUNT(*) FROM products
        <where>
            <choose>
                <when test="countType == 'on_sale'">
                    AND status = 'ON_SALE'
                </when>
                <when test="countType == 'out_of_stock'">
                    AND status = 'OUT_OF_STOCK'
                </when>
                <!-- "all" 或其他值: 不加條件，統計全部 -->
            </choose>
        </where>
    </select>

    <!-- ============================================================
         示範 2: <trim> 標籤
         可自訂 prefix、suffix、prefixOverrides、suffixOverrides
         比 <where> 和 <set> 更靈活
         ============================================================ -->

    <!--
        使用 trim 取代 where 標籤:
        - prefix="WHERE"         : 在內容前加上 WHERE
        - prefixOverrides="AND|OR" : 去掉內容開頭多餘的 AND 或 OR
    -->
    <select id="selectByTrimCondition" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM products
        <trim prefix="WHERE" prefixOverrides="AND |OR ">
            <if test="name != null and name != ''">
                AND name LIKE CONCAT('%', #{name}, '%')
            </if>
            <if test="status != null and status != ''">
                AND status = #{status}
            </if>
            <if test="categoryId != null">
                AND category_id = #{categoryId}
            </if>
        </trim>
        ORDER BY id
    </select>

    <!--
        使用 trim 取代 set 標籤:
        - prefix="SET"           : 在內容前加上 SET
        - suffixOverrides=","    : 去掉內容結尾多餘的逗號
    -->
    <update id="updateByTrim">
        UPDATE products
        <trim prefix="SET" suffixOverrides=",">
            <if test="name != null">name = #{name},</if>
            <if test="price != null">price = #{price},</if>
            <if test="stock != null">stock = #{stock},</if>
            <if test="status != null">status = #{status},</if>
            <if test="description != null">description = #{description},</if>
            updated_at = CURRENT_TIMESTAMP,
        </trim>
        WHERE id = #{id}
    </update>

    <!-- ============================================================
         示範 3: <bind> 標籤
         使用 OGNL 表達式建立變數，提升跨資料庫相容性。
         避免使用各資料庫特有的字串拼接函數 (如 CONCAT, ||)
         ============================================================ -->

    <select id="searchByName" resultMap="BaseResultMap">
        <!--
            bind 將 keyword 包裝為 LIKE 萬用字元格式，
            這樣 SQL 中可直接使用 #{pattern}，無需依賴 CONCAT 函數。
        -->
        <bind name="pattern" value="'%' + keyword + '%'"/>
        SELECT <include refid="Base_Column_List"/>
        FROM products
        WHERE name LIKE #{pattern}
        ORDER BY id
    </select>

    <!-- ============================================================
         示範 4: <foreach> 批次插入
         使用 foreach 產生 VALUES 子句，一次插入多筆資料
         ============================================================ -->

    <insert id="batchInsert">
        INSERT INTO products (name, category_id, price, stock, status, description)
        VALUES
        <foreach collection="products" item="product" separator=",">
            (#{product.name}, #{product.categoryId}, #{product.price},
             #{product.stock}, #{product.status}, #{product.description})
        </foreach>
    </insert>

    <!-- ============================================================
         示範 5: <foreach> 批次刪除
         使用 foreach 產生 IN 子句
         ============================================================ -->

    <delete id="batchDeleteByIds">
        DELETE FROM products
        WHERE id IN
        <foreach collection="ids" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <!-- ============================================================
         示範 6: 巢狀查詢 (Nested Select / 延遲載入)
         透過 resultMap 中的 association + select 屬性，
         MyBatis 會自動執行子查詢來填充關聯物件。
         配合 lazyLoadingEnabled=true 可實現按需載入。
         ============================================================ -->

    <select id="selectWithCategory" resultMap="ProductWithCategoryResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM products
        WHERE id = #{id}
    </select>

    <select id="selectAllWithCategory" resultMap="ProductWithCategoryResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM products
        ORDER BY id
    </select>

    <!-- ============================================================
         示範 7: <selectKey> 主鍵生成策略
         在 INSERT 前後執行額外的 SQL 來獲取主鍵值。
         order="AFTER" 表示在 INSERT 後執行 (適用於自增主鍵)。
         ============================================================ -->

    <insert id="insertWithSelectKey">
        <!--
            order="BEFORE": 在 INSERT 前執行，先取得下一個 ID 值，
            然後在 INSERT 語句中直接使用該 ID。

            這裡使用自訂的 product_seq 序列。
            實際專案中，可根據資料庫替換:
              - MySQL:      order="AFTER"  + SELECT LAST_INSERT_ID()
              - PostgreSQL:  order="BEFORE" + SELECT nextval('product_seq')
              - Oracle:      order="BEFORE" + SELECT product_seq.NEXTVAL FROM DUAL
        -->
        <selectKey keyProperty="id" resultType="long" order="BEFORE">
            SELECT NEXT VALUE FOR product_seq
        </selectKey>
        INSERT INTO products (id, name, category_id, price, stock, status, description)
        VALUES (#{id}, #{name}, #{categoryId}, #{price}, #{stock}, #{status}, #{description})
    </insert>

    <!-- ============================================================
         示範 8: Map 參數傳遞
         接收 Map<String, Object> 作為參數，
         直接用 key 名稱存取 Map 中的值。
         ============================================================ -->

    <select id="selectByMap" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM products
        <where>
            <if test="name != null and name != ''">
                <bind name="namePattern" value="'%' + name + '%'"/>
                AND name LIKE #{namePattern}
            </if>
            <if test="minPrice != null">
                AND price &gt;= #{minPrice}
            </if>
            <if test="maxPrice != null">
                AND price &lt;= #{maxPrice}
            </if>
            <if test="status != null and status != ''">
                AND status = #{status}
            </if>
            <if test="categoryId != null">
                AND category_id = #{categoryId}
            </if>
        </where>
        ORDER BY
        <choose>
            <when test="orderBy != null and orderBy == 'price'">price ASC</when>
            <when test="orderBy != null and orderBy == 'name'">name ASC</when>
            <otherwise>id ASC</otherwise>
        </choose>
    </select>

</mapper>

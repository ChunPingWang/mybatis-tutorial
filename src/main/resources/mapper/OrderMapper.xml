<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.mybatis.mapper.OrderMapper">

    <!-- 帶使用者的結果映射 (多對一) -->
    <resultMap id="OrderWithUserResultMap" type="Order">
        <id property="id" column="id"/>
        <result property="userId" column="user_id"/>
        <result property="product" column="product"/>
        <result property="amount" column="amount"/>
        <result property="status" column="status"/>
        <result property="createdAt" column="created_at"/>
        <association property="user" javaType="User">
            <id property="id" column="user_id"/>
            <result property="username" column="username"/>
            <result property="email" column="email"/>
            <result property="age" column="age"/>
        </association>
    </resultMap>

    <!-- 多對一關聯查詢: 查詢訂單及其所屬使用者 -->
    <select id="selectWithUser" resultMap="OrderWithUserResultMap">
        SELECT
            o.id, o.user_id, o.product, o.amount, o.status, o.created_at,
            u.username, u.email, u.age
        FROM orders o
        INNER JOIN users u ON o.user_id = u.id
        WHERE o.id = #{id}
    </select>

</mapper>
